# Copy to .env.local (gitignored) and fill in from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# From posthog.com dashboard > Project Settings > Project API Key
# Host depends on which cloud region you picked when creating the project.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
